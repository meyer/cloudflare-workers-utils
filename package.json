{
  "name": "cloudflare-workers-utils",
  "version": "0.0.0",
  "description": "Utilities for use with Cloudflare workers",
  "author": "meyer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r clean && tsc -b --diagnostics",
    "format": "oxfmt --write .",
    "lint": "oxlint",
    "check": "oxfmt --write . && oxlint --fix",
    "postinstall": "manypkg fix",
    "update-tsconfigs": "node ./scripts/updateTsconfigs.mjs",
    "release": "pnpm publish -r --access public",
    "release:canary": "pnpm publish -r  --access public --tag canary --no-git-checks",
    "test": "vitest",
    "version:canary": "changeset version --snapshot canary"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@cloudflare/workers-types": "^4.20260531.1",
    "@manypkg/cli": "^0.25.1",
    "@manypkg/get-packages": "^3.1.0",
    "@types/node": "^24.12.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.15.0"
}
