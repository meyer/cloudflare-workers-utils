{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-explicit-any": "off",
    "no-empty-interface": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["**/dist"]
}
